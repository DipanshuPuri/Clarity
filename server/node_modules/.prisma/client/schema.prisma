generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  MANAGER
}

enum IntentStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum DecisionStatus {
  PROPOSED
  APPROVED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum OutcomeResult {
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  role         Role    @default(MEMBER)
  firstName    String?
  lastName     String?
  organization String?

  decisions Decision[] @relation("UserDecisions")
  tasks     Task[]     @relation("UserTasks")
}

model Project {
  id                String @id @default(uuid())
  name              String
  problemStatement  String
  successDefinition String

  intents Intent[]
}

model Intent {
  id            String       @id @default(uuid())
  title         String
  assumption    String
  successSignal String
  status        IntentStatus @default(ACTIVE)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  decisions Decision[]
  tasks     Task[]
}

model Decision {
  id                   String         @id @default(uuid())
  title                String
  chosenOption         String
  rationale            String
  rejectedAlternatives String
  status               DecisionStatus @default(PROPOSED)
  createdAt            DateTime       @default(now())

  intentId String
  intent   Intent @relation(fields: [intentId], references: [id])

  authorId String
  author   User   @relation("UserDecisions", fields: [authorId], references: [id])

  tasks Task[]
}

model Task {
  id                   String     @id @default(uuid())
  title                String
  status               TaskStatus @default(TODO)
  executionDescription String
  expectedOutcome      String

  intentId String
  intent   Intent @relation(fields: [intentId], references: [id])

  decisionId String
  decision   Decision @relation(fields: [decisionId], references: [id])

  assigneeId String?
  assignee   User?   @relation("UserTasks", fields: [assigneeId], references: [id])

  outcome Outcome?
}

model Outcome {
  id        String        @id @default(uuid())
  result    OutcomeResult
  notes     String
  learning  String
  createdAt DateTime      @default(now())

  taskId String @unique
  task   Task   @relation(fields: [taskId], references: [id])
}
